# Ruby tools
RUN --mount=type=cache,target=/root/.cache/gem,sharing=locked \
  gem install zsteg one_gadget

# Python CLIs via pipx
ENV PATH="/root/.local/bin:${PATH}"
RUN --mount=type=cache,target=/root/.cache/pip,sharing=locked \
  pipx install git+https://github.com/RsaCtfTool/RsaCtfTool \
  && pipx install "pywhat[optimize]" \
  && pipx install factordb-pycli \
  && pipx install slither-analyzer \
  && pipx install frida-tools \
  && pipx install objection
#   && pipx install graphw00f

ARG CIPHEY_WHEEL_URL="https://github.com/liudonghua123/CipheyCore/releases/download/0.3.2/ciphey-5.14.0-py3-none-any.whl"
ARG CIPHEYCORE_WHEEL_URL="https://github.com/liudonghua123/CipheyCore/releases/download/0.3.2/cipheycore-0.3.2-cp313-cp313-manylinux_2_31_x86_64.whl"
RUN --mount=type=cache,target=/root/.cache/pip,sharing=locked \
    set -eux; \
    mkdir -p /tmp/ciphey && cd /tmp/ciphey; \
    wget -q "${CIPHEY_WHEEL_URL}"; \
    wget -q "${CIPHEYCORE_WHEEL_URL}"; \
    \
    # Patch ciphey wheel dependency pin for absl-py (in-place)
    mkdir -p w && cd w; \
    python3 -m zipfile -e ../ciphey-5.14.0-py3-none-any.whl .; \
    sed -i 's/^Requires-Dist: absl-py ==0\\.9\\.0$/Requires-Dist: absl-py >=0.12.0/' ciphey-5.14.0.dist-info/METADATA; \
    rm -f ../ciphey-5.14.0-py3-none-any.whl; \
    python3 -m zipfile -c ../ciphey-5.14.0-py3-none-any.whl .; \
    cd ..; \
    \
    # Install into a dedicated venv
    python3 -m venv /opt/ciphey; \
    /opt/ciphey/bin/pip install -U pip setuptools wheel; \
    /opt/ciphey/bin/pip install ./cipheycore-0.3.2-cp313-cp313-manylinux_2_31_x86_64.whl; \
    /opt/ciphey/bin/pip install --no-deps ./ciphey-5.14.0-py3-none-any.whl; \
    /opt/ciphey/bin/pip install \
      "flake8>=3.8.4,<4.0.0" \
      "appdirs>=1.4.4,<2.0.0" \
      "base58>=2.0.1,<3.0.0" \
      "base91>=1.0.1,<2.0.0" \
      "cipheydists>=0.3.34,<0.4.0" \
      "click>=7.1.2,<9.0.0" \
      "loguru>=0.5.3,<0.6.0" \
      "mock>=4.0.3,<5.0.0" \
      "pybase62>=0.4.3,<0.5.0" \
      "pylint>=2.6.0,<3.0.0" \
      "pywhat>=0.2.5,<1.2.0" \
      "pyyaml" \
      "rich>=4,<11" \
      "absl-py>=0.12.0" ; \
    \
    ln -sf /opt/ciphey/bin/ciphey /usr/local/bin/ciphey; \
    ciphey --help >/dev/null; \
    rm -rf /tmp/ciphey

# Pwn tools (heavy, separate)
RUN git clone https://github.com/pwndbg/pwndbg /opt/pwndbg \
    && cd /opt/pwndbg && ./setup.sh \
    && bash -c "$(curl -fsSL https://gef.blah.cat/sh)"

# External binary downloads: pwninit
RUN wget -q https://github.com/io12/pwninit/releases/download/3.3.1/pwninit -O /usr/local/bin/pwninit \
    && chmod +x /usr/local/bin/pwninit

WORKDIR /challenge
CMD ["sleep", "infinity"]
